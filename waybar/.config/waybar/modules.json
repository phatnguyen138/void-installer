{

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{icon}",
    // "format": "< %g >",
    // "format_focused" : "< %g έΩΠ >",
    "format-icons": {
      "1": "ΎΕι",
      "2": "ΎΚσ",
      "3": "ΎΒ╗",
      "4": "ΎΕκ",
      "5": "ΎΖς",
      "6": "ΎΓΗ",
      "7": "ΎΓδ",
      "8": "ΎΘΑ",
      "9": "ΎΗα",
      "10": "ΎΕΣ"
    }
  },

  "custom/swap": {
    "on-click": "~/.config/waybar/scripts/swap.sh",
    "format": "Bg ΎΙΕ ",
    "tooltip": true,
    "tooltip-format": "Swap between waybar Themes"
  },

  "sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "sway/window": {
        "rewrite": {
            "(.*) - Brave": "$1",
            "(.*) - Chromium": "$1",
            "(.*) - Brave Search": "$1",
            "(.*) - Outlook": "$1",
            "(.*) Microsoft Teams": "$1"
        },
        "separate-outputs": true,
    "format": "<span color=\"#24273a\" style=\"italic\">{}</span>"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ΎΠΒ",
      "deactivated": "ΎΑμ"
    }
  },
  "tray": {
    // "icon-size": 14,
    "spacing": 5
  },
  "clock": {
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
	"months": "<span color='#bb9af7'><b>{}</b></span>",  // Purple
	"days": "<span color='#7aa2f7'><b>{}</b></span>",    // Blue
	"weeks": "<span color='#9ece6a'><b>W{}</b></span>",  // Green
	"weekdays": "<span color='#e0af68'><b>{}</b></span>",// Yellow
	"today": "<span background='#2ac3de' color='#1a1b26'><b><u>{}</u></b></span>" // Cyan background with dark text
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
    "format": "{:%a %d %b | %I:%M %p}", //12 hour format
    "format-alt": "ΎΕ│  {:%Y-%m-%d ΎΑΩ %H:%M:%S}",
    "interval": 1
  },

  // System
  "custom/system": {
    "format": "ΌΣ│",
    "tooltip": false
  },
  "cpu": {
    "format": "ΎΜδ {usage: >3}%",
    "on-click": "alacritty -e htop"
  },
  "memory": {
    "format": "ΎΜδ {: >3}%",
    "on-click": "alacritty -e htop"
  },
  "temperature": {
    "thermal-zone": 4,
    // "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
    "critical-threshold": 80,
    // "format-critical": "{temperatureC}┬░C ΎΜΘ",
    "format": "ΎΜΚ  {temperatureC}┬░C"
  },
  // Harddisc space used
  "disk": {
    // "interval": 30,
    "format": "ΎΓι {percentage_used}% ",
    "path": "/"
    //"on-click": "alacritty -e htop"
  }, 
    // Group Hardware
    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 300,
            "children-class": "not-memory",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/system",
            "disk",
            "cpu"
            // "backlight",
            //"sway/language"
        ]
    },
  "backlight": {
    // "device": "acpi_video1",
    "format": "{icon} {percent: >3}%",
    // "format-icons": ["ΎΗΖ", "ΎΕΣ"],
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
    "on-scroll-down": "brightnessctl -c backlight set 5%-",
    // "on-scroll-down": "light -A 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob",
    "on-scroll-up": "brightnessctl -c backlight set +5%",
    // "on-scroll-up": "light -U 5 && light -G | cut -d'.' -f1 > $SWAYSOCK.wob"
    "on-click": ""
  },
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity: >3}%",
    "format-charging": "{icon} ΎΔπ {capacity}%",
    "format-plugged": "{icon} ΎΘο {capacity}%",
    "format-alt": "{icon} {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
  },
  "network": {
    // "interface": "wlp2s0", // (Optional) To force the use of this interface
    "format": "έγι  Disabled",
    "format-wifi": "ΎΘτ  {essid}",
    // "format-ethernet": "ΎΔΒ {ifname}: {ipaddr}/{cidr}",
    "format-ethernet": "ΎΔΒ  Wired",
    "format-disconnected": "έγι  Disconnected",
    "tooltip-format": "ΎηΨ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "ΎΘτ   {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "ΎΔΒ  {ifname} ({ipaddr}/{cidr})",
    "tooltip-format-disconnected": "έγι  Disconnected",
    // "on-click": "ghostty -e nmtui"
    "on-click": "nm-connection-editor"
  },
  "pulseaudio": {
    // "scroll-step": 5,
    "format": "{icon} {volume: >3}%",
    "format-bluetooth": "{icon} {volume: >3}%",
    "format-muted": "ΎΑο muted",
    "format-icons": {
      "headphones": "ΎΑξ",
      "handsfree": "ΎΑξ",
      "headset": "ΎΑξ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pavucontrol",
    // "on-scroll-up": "pamixer -ui 2 && pamixer --get-volume > $SWAYSOCK.wob",
    // "on-scroll-down": "pamixer -ud 2 && pamixer --get-volume > $SWAYSOCK.wob"
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
  },
  "custom/xbps": {
    "format": "ΎΗΘ {}",
    "interval": 7200,
    "exec": "i=$(xbps-install -Mun); echo \"$i\" |wc -l; echo \"$i\" |column -t |tr '\n' '\r'",
    "exec-if": "exit 0",
    "on-click": "alacritty -e sudo xbps-install -Su",
    "signal": 8
  },
  "custom/power": {
    "format": "έΠ╗",
    // "on-click": "wlogout -p layer-shell",
    "on-click": "~/.config/rofi/powermenu/powermenu.sh",
    "tooltip": false
  },
  "custom/keyboard-layout": {
    "exec": "swaymsg -t get_inputs | grep -m1 'xkb_active_layout_name' | cut -d '\"' -f4",
    // Interval set only as a fallback, as the value is updated by signal
    "interval": 1,
    "format": "ΎΕε  {}", // Icon: keyboard
    // Signal sent by Sway key binding (~/.config/sway/key-bindings)
    "signal": 1, // SIGHUP
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/keyhint.sh"
  },
  "custom/launcher": {
    "format": "ΎΑΧ",
    "on-click": "rofi -show drun -replace",
    "tooltip": false
  }
}
